// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Release {
  id                String   @id @default(uuid())
  versionName       String   // e.g., "Version 1.1.0"
  createdAt         DateTime @default(now()) // Automatically set on creation
  additionalRemarks String?  // Optional text input
  stepsState        Json     // Stores the 7 fixed steps as boolean key/values
}